{
  "manifest_version": 3,
  "name": "GitHub Repo New Tab",
  "description": "See your GitHub repositories every time you open a new tab.",
  "version": "1.0.0",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "options_page": "options.html",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
